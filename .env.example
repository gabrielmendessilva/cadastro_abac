APP_NAME="Abac"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sistema_ged
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Omie API (integração financeira)
URL_OMIE=https://app.omie.com.br/api/
OMIE_APP_KEY=
OMIE_APP_SECRET=
OMIE_TIMEOUT=30

# TOTVS RM (SQL Server) — importação de clientes/fornecedores (rm:import)
RM_DB_HOST=
RM_DB_PORT=1433
RM_DB_DATABASE=CorporeRM
RM_DB_USERNAME=
RM_DB_PASSWORD=
RM_DB_ENCRYPT=yes                      # usar 'no' se o SQL Server for antigo (sem TLS 1.2)
RM_DB_TRUST_SERVER_CERTIFICATE=true    # certificado auto-assinado
RM_DB_LOGIN_TIMEOUT=15
RM_DB_QUERY_TIMEOUT=300
RM_IMPORT_CHUNK=300

# MySQL do sistema legado abac_admin (leitura pontual de dados)
ABAC_ADMIN_DB_HOST=
ABAC_ADMIN_DB_PORT=3306
ABAC_ADMIN_DB_DATABASE=
ABAC_ADMIN_DB_USERNAME=
ABAC_ADMIN_DB_PASSWORD=
